{
  "name": "teampitch",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Cloudflare-hosted assistant workspace",
  "license": "MIT",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @teampitch/worker dev",
    "start": "bun run dev",
    "build": "bun run --filter @teampitch/worker build",
    "deploy": "bun run --filter @teampitch/worker deploy",
    "types": "bun run --filter @teampitch/worker types",
    "hooks:install": "lefthook install",
    "test": "bun run --filter @teampitch/worker test",
    "evals": "bun run --filter @teampitch/worker evals",
    "test:all": "bun run test && bun run evals",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "bun run --filter @teampitch/worker lint",
    "health": "fallow --summary",
    "health:full": "fallow",
    "health:score": "fallow health --score --hotspots --targets",
    "health:report": "mkdir -p artifacts/fallow && fallow --format markdown --output-file artifacts/fallow/health.md || true && fallow --format json --output-file artifacts/fallow/health.json || true && fallow --format sarif --output-file artifacts/fallow/health.sarif || true",
    "dead-code": "fallow dead-code",
    "dupes": "fallow dupes",
    "audit": "fallow audit --format compact --base ${FALLOW_BASE:-origin/master}",
    "check": "bun run format:check && bun run --filter @teampitch/worker check",
    "check:all": "bun run check && bun run audit"
  },
  "devDependencies": {
    "fallow": "^2.91.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0"
  },
  "packageManager": "bun@1.3.8"
}
