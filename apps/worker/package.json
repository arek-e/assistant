{
  "name": "@teampitch/worker",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker and Agents runtime for Teampitch",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "typecheck": "tsc",
    "test": "bun test",
    "test:all": "bun run test && bun run evals",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/ evals/",
    "evals": "bun run evals/run.ts",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run evals"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.8.0",
    "@cloudflare/think": "^0.8.8",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons-pro/core-bulk-rounded": "^4.2.0",
    "@hugeicons-pro/core-solid-rounded": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@streamdown/code": "^1.1.1",
    "@teampitch/ui": "workspace:*",
    "agents": "^0.15.0",
    "ai": "^6.0.194",
    "effect": "^3.21.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "workers-ai-provider": "^3.1.14"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@cloudflare/vite-plugin": "1.39.1",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0"
  },
  "packageManager": "bun@1.3.8"
}
