{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/config-schema.json",
  "ignoreDependencies": [
    "@babel/plugin-proposal-decorators",
    "@rolldown/plugin-babel"
  ],
  "duplicates": {
    "ignore": ["packages/ui/src/components/ui/**"]
  },
  "health": {
    "ignore": ["packages/ui/src/components/ui/**"]
  },
  "usedClassMembers": [
    {
      "extends": "AIChatAgent",
      "members": [
        "maxPersistedMessages",
        "onStart",
        "onChatMessage",
        "executeTask"
      ]
    }
  ]
}
