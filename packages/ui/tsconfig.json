{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["react"]
  },
  "include": ["src"]
}
