{
  "name": "@teampitch/ui",
  "version": "1.0.0",
  "private": true,
  "description": "Shared Coss UI primitives for Teampitch apps",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./components/*": {
      "types": "./src/components/ui/*.tsx",
      "default": "./src/components/ui/*.tsx"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./lib/surface-tokens": {
      "types": "./src/lib/surface-tokens.ts",
      "default": "./src/lib/surface-tokens.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    }
  },
  "scripts": {
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "packageManager": "bun@1.3.8"
}
