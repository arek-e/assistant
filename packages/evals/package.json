{
  "name": "@teampitch/evals",
  "version": "1.0.0",
  "private": true,
  "description": "Assistant primitive eval harness for Teampitch",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "evals": "bun run src/run.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run evals"
  },
  "dependencies": {
    "@teampitch/worker": "workspace:*",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.8"
}
